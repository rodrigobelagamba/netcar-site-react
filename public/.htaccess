# Home servida via index.php (injeta preload do banner para melhorar LCP).
# Se PHP não estiver disponível, cai no index.html normalmente.
<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

# Configuração de tipos MIME (deve vir primeiro)
<IfModule mod_mime.c>
  # JavaScript modules
  AddType application/javascript js mjs
  AddType text/javascript js mjs
  
  # JSON
  AddType application/json json webmanifest
  
  # CSS
  AddType text/css css
</IfModule>

# Configurações de cache para assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Imagens
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS e JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 0 seconds"
  
  # Fontes
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # HTML (sem cache para permitir atualizações)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Compressão GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Headers de segurança
<IfModule mod_headers.c>
  # Previne clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Previne MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # XSS Protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Corrige tipo MIME para JavaScript modules
  <FilesMatch "\.(js|mjs)$">
    Header set Content-Type "application/javascript"
  </FilesMatch>

  # Banners e fotos do sistema legado (/imagens/) estavam saindo com
  # Cache-Control: max-age=1800 (30 min). Banner muda raramente: 7 dias.
  <If "%{REQUEST_URI} =~ m#^/imagens/#">
    Header set Cache-Control "public, max-age=604800"
  </If>

  # Assets do build (/assets/) têm hash no nome (ex.: index-Rjk3oydK.js):
  # o conteúdo nunca muda para um mesmo arquivo, então cache de 1 ano + immutable.
  # Em produção estavam saindo com max-age=1800 (30 min), forçando re-download
  # a cada visita e penalizando LCP de retorno. immutable evita revalidação.
  <If "%{REQUEST_URI} =~ m#^/assets/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>
</IfModule>

# Rewrite Rules para SPA
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # HTTPS canônico (http -> https://www)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.netcarmultimarcas.com.br%{REQUEST_URI} [R=301,L]
  
  # Canônico da home: /index.html acessado direto -> / (301).
  # THE_REQUEST garante que só o request externo do browser/crawler é
  # redirecionado; o rewrite interno do SPA para index.html não casa aqui.
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]
  
  # Redirects 301 — site legado PHP/HTML
  RewriteRule ^seminovos\.php$ /seminovos [R=301,L]
  RewriteRule ^sobre-nos\.php$ /sobre [R=301,L]
  RewriteRule ^listagem-produtos\.php$ /seminovos [R=301,L]
  RewriteRule ^clientes\.php$ / [R=301,L]
  RewriteRule ^contato\.php$ /contato [R=301,L]
  RewriteRule ^contato\.html$ /contato [R=301,L]
  RewriteRule ^ficha-cadastral\.php$ /seminovos [R=301,L]
  RewriteRule ^detalhe-produto-(.+)\.html?$ /seminovos [R=301,L]
  RewriteRule ^detalhe-produto-(.+)$ /seminovos [R=301,L]
  
  # Home para bots: precisa vir ANTES do short-circuit de arquivo/diretório,
  # senão a raiz "/" casa com o diretório docroot (-d) e o crawler recebe o
  # index.html (shell vazio do React) em vez do conteúdo real do seo-pagina.php.
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|Slackbot-LinkExpanding|Slack-ImgProxy|Google-Structured-Data-Testing-Tool|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteCond %{REQUEST_URI} ^/?$ [NC]
  RewriteRule ^$ seo-pagina.php [L,QSA]
  
  # PHP social — antes do fallback SPA (reviews, stories, oauth, sync)
  RewriteRule ^social/v1/.+\.php$ - [L]

  # Bridge social — PHP antes do React (paginação reviews/stories legado)
  RewriteRule ^embedsocial-bridge\.php$ - [L]

  # Feed WhatsApp Catalog — sempre ao vivo via API (antes do -f estático)
  RewriteRule ^feeds/whatsapp-catalog\.csv$ feeds/whatsapp-catalog.php?format=csv [L,QSA]
  RewriteRule ^feeds/whatsapp-catalog\.xml$ feeds/whatsapp-catalog.php?format=xml [L,QSA]
  RewriteRule ^feeds/whatsapp-catalog\.php$ - [L]

  # Primeiro: servir só arquivos reais (-f).
  # NÃO usar -d aqui: o docroot de produção ainda tem pastas legadas
  # (seminovos/, veiculo/, etc.) que interceptavam a URL e mandavam para not-found.html.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
  
  # Segundo: não reescrever arquivos estáticos por extensão
  RewriteCond %{REQUEST_URI} \.(js|mjs|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|webmanifest|xml|txt|map)$ [NC]
  RewriteRule ^ - [L]
  
  # Terceiro: não reescrever pasta assets
  RewriteCond %{REQUEST_URI} ^/assets/ [NC]
  RewriteRule ^ - [L]
  
  # Quarto: não reescrever index.html e not-found.html (evita loops)
  RewriteCond %{REQUEST_URI} ^/(index|not-found)\.html$ [NC]
  RewriteRule ^ - [L]
  
  # Sexto: interceptar rotas principais para bots (HTML com conteúdo real)
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|Slackbot-LinkExpanding|Slack-ImgProxy|Google-Structured-Data-Testing-Tool|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteCond %{REQUEST_URI} ^/(seminovos|sobre|contato|compra|blog)/?$ [NC]
  RewriteRule ^ seo-pagina.php [L,QSA]

  # SEO estático para crawlers (blog + páginas locais)
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^blog/([^/]+)/?$ seo-static/blog-$1.html [L]

  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^seminovos-([a-z0-9-]+)/?$ seo-static/city-$1.html [L]

  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^vender-carro-([a-z0-9-]+)/?$ seo-static/sell-city-$1.html [L]

  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^comprar-([a-z0-9-]+)/?$ seo-static/landing-$1.html [L]

  # Páginas de conteúdo SEO (financiamento, atendimento-24h) para crawlers
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^(financiamento|atendimento-24h)/?$ seo-static/page-$1.html [L]

  # Sétimo: interceptar /veiculo/{slug} APENAS quando for bot/crawler (meta tags para WhatsApp)
  # Usuários normais acessam diretamente o React app
  RewriteCond %{REQUEST_URI} ^/veiculo/ [NC]
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|WhatsApp|WhatsAppBot|Twitterbot|LinkedInBot|Slackbot|SkypeUriPreview|Googlebot|bingbot|Baiduspider|YandexBot|DuckDuckBot|curl|wget|facebook|Facebot|Slurp|ia_archiver|Mediapartners|Applebot|BingPreview|Slackbot-LinkExpanding|Slack-ImgProxy|Slackbot|SkypeUriPreview|LinkedInBot|Twitterbot|WhatsApp|facebookexternalhit|Facebot|Google-Structured-Data-Testing-Tool|bot|crawler|spider|scraper) [NC,OR]
  RewriteCond %{QUERY_STRING} _escaped_fragment_= [NC]
  RewriteRule ^veiculo/(.+)$ detalhe-veiculo.php?slug=$1 [L,QSA]
  
  # SPA React — index.php serve o shell (home ganha preload LCP via PHP)
  RewriteRule ^ index.php [L]
</IfModule>
