# Dependencies
node_modules/

# Build output
dist/

# PDF i-CHECK gerado localmente
output/

# Estado local do painel devops (último deploy registrado)
.devops/

# Environment variables (não versionar — copie de .env.example)
.env
.env.local
.env.*.local
.env.development
.env.production
# Apenas o exemplo fica no repositório
!.env.example

# Gerado no build a partir do .env.production
public/netcar-config.php

# Gerado no build (generate-landings / generate-seo-assets / generate-sitemap)
public/seo-static/
public/sitemap.xml
public/feeds/*
src/data/seo/landings.json

# Social sync — credenciais e tokens (KingHost)
docs/social/social-config.php
docs/social/data/cache/social-tokens.json
docs/social/data/cache/google-reviews.json
docs/social/data/cache/stories.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# PDF i-CHECK gerado: versiona autocheck pra overwrite no deploy
public/arquivos/*
!public/arquivos/autocheck/
public/arquivos/autocheck/*
!public/arquivos/autocheck/*.pdf
!public/arquivos/autocheck/*.meta.json
