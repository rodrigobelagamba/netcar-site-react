# Deploy local — copie para .env.local

# Recomendado na KingHost dedicada (você já tem SSH):
DEPLOY_METHOD=ssh
SSH_HOST=netcarmultimarcas.com.br
SSH_USER=netcarmultimarcas
SSH_DIR=www/

# Evitar digitar senha a cada deploy:
# 1) (recomendado) Rode uma vez: npm run deploy:ssh-setup
# 2) Ou aponte para sua chave (padrão: ~/.ssh/id_ed25519):
# SSH_KEY_PATH=C:/Users/SEU_USUARIO/.ssh/id_ed25519
# 3) Ou senha no .env.local + sshpass instalado (menos seguro):
# SSH_PASSWORD=sua_senha_ssh

# Alternativa FTP (se DEPLOY_METHOD=ftp):
# FTP_SERVER=ftp.netcarmultimarcas.com.br
# FTP_USERNAME=seu_usuario
# FTP_PASSWORD=sua_senha
# FTP_SERVER_DIR=/www/
# FTP_SECURE=true
