# Deploy local — copie para .env.local

# Recomendado na KingHost dedicada (você já tem SSH):
DEPLOY_METHOD=ssh
SSH_HOST=netcarmultimarcas.com.br
SSH_USER=netcarmultimarcas
SSH_DIR=www/

# Alternativa FTP (se DEPLOY_METHOD=ftp):
# FTP_SERVER=ftp.netcarmultimarcas.com.br
# FTP_USERNAME=seu_usuario
# FTP_PASSWORD=sua_senha
# FTP_SERVER_DIR=/www/
# FTP_SECURE=true
