# API Configuration
# Copie para .env.development (npm run dev) ou .env.production (npm run build)
# Estes arquivos não são versionados — preencha com os valores reais na sua máquina ou no CI.

# URL base da API Netcar
# Desenvolvimento: http://localhost/.../api/v1 ou URL do ambiente local
# Produção: https://www.netcarmultimarcas.com.br/api/v1
VITE_API_BASE_URL=https://www.netcarmultimarcas.com.br/api/v1

# Timeout das requisições (em milissegundos)
VITE_API_TIMEOUT=30000

# Caminho base do app (geralmente / em produção)
VITE_BASE_PATH=/

# Google Maps — chave restrita por referrer no Google Cloud (aparece no bundle)
VITE_GOOGLE_MAPS_API_KEY=

# Selo de campanha nos cards/detalhes (opcional; padrão true se omitido)
# VITE_SHOW_CAMPAIGN_STAMP=true
